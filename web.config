<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <!-- 預設（HTML 與其他靜態檔）：no-cache，每次必 revalidate -->
  <system.webServer>
    <staticContent>
      <clientCache cacheControlMode="DisableCache" />
    </staticContent>
  </system.webServer>

  <!-- layout.js：固定檔名 + 內容會變，每次 revalidate -->
  <location path="layout.js">
    <system.webServer>
      <staticContent>
        <clientCache cacheControlMode="DisableCache" />
      </staticContent>
    </system.webServer>
  </location>

  <!-- i18n.js：同上 -->
  <location path="i18n.js">
    <system.webServer>
      <staticContent>
        <clientCache cacheControlMode="DisableCache" />
      </staticContent>
    </system.webServer>
  </location>

  <!-- images/：browser 快取 1 天 -->
  <location path="images">
    <system.webServer>
      <staticContent>
        <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="1.00:00:00" />
      </staticContent>
    </system.webServer>
  </location>
</configuration>
