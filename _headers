# HTML 與根路徑：每次必 revalidate（透過 etag 比對，沒改不會重下載）
/
  Cache-Control: public, max-age=0, must-revalidate
/*.html
  Cache-Control: public, max-age=0, must-revalidate

# 共用 JS：固定檔名 + 內容會變，必 revalidate
/layout.js
  Cache-Control: public, max-age=0, must-revalidate
/i18n.js
  Cache-Control: public, max-age=0, must-revalidate

# 圖片：1 天 browser cache，仍 revalidate；換檔名即自然 bust
/images/*
  Cache-Control: public, max-age=86400, must-revalidate
